generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mongodb"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id            String                    @id @default(auto()) @map("_id") @db.ObjectId
  email         String                    @unique
  password      String
  createdAt     DateTime                  @default(now())
  journeys      Journey[]
  accessibility UserAccessibilityProfile?
}

model Journey {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  user      User          @relation(fields: [userId], references: [id])
  userId    String        @db.ObjectId
  status    JourneyStatus @default(PLANNED)
  totalCost Float?
  totalTime Int?
  createdAt DateTime      @default(now())
  legs      JourneyLeg[]
  booking   Booking?
  payments  Payment[]
}

model JourneyLeg {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  journey     Journey       @relation(fields: [journeyId], references: [id])
  journeyId   String        @db.ObjectId
  mode        TransportMode
  source      String
  destination String
  cost        Float
  duration    Int
  order       Int
  status      LegStatus     @default(PENDING)

  ticket      Ticket?
  travelPass  LegTravelPass?
}

model Booking {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  journey   Journey       @relation(fields: [journeyId], references: [id])
  journeyId String        @unique @db.ObjectId
  status    BookingStatus
  createdAt DateTime      @default(now())
}

model Payment {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  journey     Journey       @relation(fields: [journeyId], references: [id])
  journeyId   String        @db.ObjectId
  amount      Float
  currency    String        @default("INR")
  status      PaymentStatus @default(PENDING)
  provider    String
  providerRef String?
  breakdown   Json
  createdAt   DateTime      @default(now())
}

model Ticket {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  journeyLeg   JourneyLeg   @relation(fields: [journeyLegId], references: [id])
  journeyLegId String       @unique @db.ObjectId
  provider     String
  externalRef  String?
  status       TicketStatus @default(PENDING)
  createdAt    DateTime     @default(now())
}

model LegTravelPass {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  journeyLeg   JourneyLeg @relation(fields: [journeyLegId], references: [id])
  journeyLegId String     @unique @db.ObjectId

  qrData       String?
  validFrom    DateTime
  validTill    DateTime
  createdAt    DateTime   @default(now())
}

model UserAccessibilityProfile {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  userId     String @unique @db.ObjectId
  user       User   @relation(fields: [userId], references: [id])

  wheelchair Boolean @default(false)
  blind      Boolean @default(false)
  deaf       Boolean @default(false)
  cognitive  Boolean @default(false)
  fatigue    Boolean @default(false)

  createdAt  DateTime @default(now())
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum TicketStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum JourneyStatus {
  PLANNED
  BOOKED
  COMPLETED
  CANCELLED
}

enum TransportMode {
  METRO
  BUS
  AUTO
  CAB
  TRAIN
  WALK
}

enum LegStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  SUCCESS
  FAILED
  PENDING
}